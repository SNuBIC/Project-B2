+// Vlasov electrons, Vlasov ions, Poisson
+
+VeViPAF::VeViPAF(const Block_id &block_id, Mpi_boundary &mpi_boundary,
+                 const Parameter &parameter)
+    : block_id_(block_id), boundary_(mpi_boundary), parameter_(parameter) {
+
+  vlasov_e_ =
+      new model::Vlasov(parameter_, parameter_.species[parameter_.kElectron]);
+  vlasov_i_ =
+      new model::Vlasov(parameter_, parameter_.species[parameter_.kIon]);
+  poisson_ = new model::Poisson(parameter_);
+
+  rho_ = new real[parameter_.ncellsAF_x]();
+  residual_ = new real[parameter_.ncellsAF_x]();
+  conjugate_ = new real[parameter_.ncellsAF_x]();
+  resres_ = new real;
+  pAp_ = new real;
+  beta_ = new real;
+#pragma acc enter data copyin(rho_ [0:parameter_.ncellsAF_x])
+#pragma acc enter data copyin(residual_ [0:parameter_.ncellsAF_x])
+#pragma acc enter data copyin(conjugate_ [0:parameter_.ncellsAF_x])
+#pragma acc enter data copyin(resres_ [0:1])
+#pragma acc enter data copyin(pAp_ [0:1])
+#pragma acc enter data copyin(beta_ [0:1])
+}
+
+VeViPAF::~VeViPAF() {
+#pragma acc exit data delete (rho_ [0:parameter_.ncellsAF_x])
+
+  delete[] beta_;
+  delete[] pAp_;
+  delete[] resres_;
+  delete[] conjugate_;
+  delete[] residual_;
+  delete[] rho_;
+
+  delete poisson_;
+  delete vlasov_i_;
+  delete vlasov_e_;
+}
+
+int VeViPAF::get_scheme_id() { return parameter_.kVeViPAF; }
+
+real VeViPAF::get_dt(int species) { return dt_; }
+
+void VeViPAF::init() {
+
+  if (parameter_.restart) {
+
+    restart::load_field(vlasov_e_->f, 0, parameter_.output_directory,
+                        block_id_.my_coords);
+    restart::load_field(vlasov_i_->f, 1, parameter_.output_directory,
+                        block_id_.my_coords);
+    restart::load_field(poisson_->phi, 2, parameter_.output_directory,
+                        block_id_.my_coords);
+#pragma acc update device(                                                     \
+    vlasov_e_->f [0:parameter_.species[parameter_.kElectron].ncellsAF_xv],     \
+    vlasov_i_->f [0:parameter_.species[parameter_.kIon].ncellsAF_xv],          \
+    poisson_->phi [0:parameter_.ncellsAF_x])
+  } else {
+    // load setup
+    model::Model *plasma_models[2] = {vlasov_e_, vlasov_i_};
+    setupAF::init(plasma_models, poisson_, parameter_);
+
+    // calc rho
+    convert::f_to_rho_af(rho_, vlasov_e_->f, vlasov_i_->f, parameter_);
+    if (parameter_.bd_cond_phi[0].find("pp") != std::string::npos) {
+      real rho_average = poisson_->sum_rho_af(rho_);
+      real ncells_cg = 0.;
+      if (parameter_.dimensionality_x == 1)
+        ncells_cg = parameter_.size_x[0] - 1.;
+      if (parameter_.dimensionality_x == 2)
+        ncells_cg = (parameter_.size_x[0] - 1.) * (parameter_.size_x[1] - 1.);
+      if (parameter_.dimensionality_x == 3)
+        ncells_cg = (parameter_.size_x[0] - 1.) * (parameter_.size_x[1] - 1.) *
+                    (parameter_.size_x[2] - 1.);
+
+      rho_average = rho_average / ncells_cg;
+      rho_average =
+          boundary_.mpi_sum(rho_average) /
+          (parameter_.nproc[0] * parameter_.nproc[1] * parameter_.nproc[2]);
+      util::array_add_scalar(rho_, -rho_average, parameter_.ncellsAF_x);
+    }
+
+    // poisson
+    poisson_->conj_grad_start_af(rho_, residual_, conjugate_);
+    std::string orientation_phi[1] = {"ccc"};
+    boundary_.exchange_field_AF(conjugate_, parameter_.bd_cond_phi,
+                                orientation_phi, 1);
+    boundary_.exchange_field_border_AF(conjugate_, parameter_.bd_cond_phi,
+                                       orientation_phi, 1);
+
+    for (int i = 0; i < parameter_.cg_iterations; ++i) {
+
+      poisson_->conj_grad1_af(residual_, conjugate_, resres_, pAp_);
+      *resres_ = boundary_.mpi_sum(*resres_);
+      *pAp_ = boundary_.mpi_sum(*pAp_);
+
+      poisson_->conj_grad2_af(residual_, conjugate_, resres_, pAp_, beta_);
+      *resres_ = boundary_.mpi_sum(*resres_);
+
+      // exit criterion
+      real residual_norm = sqrt(*resres_);
+      if (residual_norm < parameter_.poisson_convergence_threshold) {
+
+        std::string orientation_phi[1] = {"ccc"};
+        boundary_.exchange_field_AF(poisson_->phi, parameter_.bd_cond_phi,
+                                    orientation_phi, 1);
+        boundary_.exchange_field_border_AF(
+            poisson_->phi, parameter_.bd_cond_phi, orientation_phi, 1);
+        break;
+      }
+
+      poisson_->conj_grad3_af(residual_, conjugate_, resres_, beta_);
+
+      std::string orientation_phi[1] = {"ccc"};
+      boundary_.exchange_field_AF(conjugate_, parameter_.bd_cond_phi,
+                                  orientation_phi, 1);
+      boundary_.exchange_field_border_AF(conjugate_, parameter_.bd_cond_phi,
+                                         orientation_phi, 1);
+    }
+  }
+  poisson_->calc_E_from_phi_af();
+
+  // needed for Vlasov's first half-step v
+  std::string orientation_E[3] = {"ccc", "ccc", "ccc"};
+  boundary_.exchange_field_AF(poisson_->E, parameter_.bd_cond_E, orientation_E,
+                              3);
+
+  // calc dt
+  dt_ = std::min(vlasov_e_->get_max_dt(), vlasov_i_->get_max_dt());
+  dt_ = boundary_.mpi_min(dt_);
+}
+
+void VeViPAF::step(int nsteps_total) {
+
+  // vlasov
+  // half step v
+
+  if (parameter_.dimensionality_v > 2) { // 0.5 z
+    vlasov_e_->step_vz(dt_ * 0.5 * 0.5, *poisson_->E, *poisson_->B,
+                       include_boundary_cells_);
+    vlasov_i_->step_vz(dt_ * 0.5 * 0.5, *poisson_->E, *poisson_->B,
+                       include_boundary_cells_);
+  }
+  exchange_plasma_solvers(vlasov_e_->f, vlasov_i_->f);
+  if (parameter_.dimensionality_v > 1) { // 0.5 y
+    vlasov_e_->step_vy(dt_ * 0.5 * 0.5, *poisson_->E, *poisson_->B,
+                       include_boundary_cells_);
+    vlasov_i_->step_vy(dt_ * 0.5 * 0.5, *poisson_->E, *poisson_->B,
+                       include_boundary_cells_);
+  }
+  exchange_plasma_solvers(vlasov_e_->f, vlasov_i_->f);
+  vlasov_e_->step_vx(dt_ * 0.5, *poisson_->E, *poisson_->B,
+                     include_boundary_cells_); // 1. x
+  vlasov_i_->step_vx(dt_ * 0.5, *poisson_->E, *poisson_->B,
+                     include_boundary_cells_);
+  exchange_plasma_solvers(vlasov_e_->f, vlasov_i_->f);
+  if (parameter_.dimensionality_v > 1) { // 0.5 y
+    vlasov_e_->step_vy(dt_ * 0.5 * 0.5, *poisson_->E, *poisson_->B,
+                       include_boundary_cells_);
+    vlasov_i_->step_vy(dt_ * 0.5 * 0.5, *poisson_->E, *poisson_->B,
+                       include_boundary_cells_);
+  }
+  exchange_plasma_solvers(vlasov_e_->f, vlasov_i_->f);
+  if (parameter_.dimensionality_v > 2) { // 0.5 z
+    vlasov_e_->step_vz(dt_ * 0.5 * 0.5, *poisson_->E, *poisson_->B,
+                       include_boundary_cells_);
+    vlasov_i_->step_vz(dt_ * 0.5 * 0.5, *poisson_->E, *poisson_->B,
+                       include_boundary_cells_);
+  }
+
+  exchange_plasma_solvers(vlasov_e_->f, vlasov_i_->f);
+
+  // step x
+  vlasov_e_->step_x(dt_);
+  vlasov_i_->step_x(dt_);
+  if (parameter_.dimensionality_x > 1) {
+    vlasov_e_->step_y(dt_);
+    vlasov_i_->step_y(dt_);
+  }
+  if (parameter_.dimensionality_x > 2) {
+    vlasov_e_->step_z(dt_);
+    vlasov_i_->step_z(dt_);
+  }
+
+  // calc rho
+  convert::f_to_rho_af(rho_, vlasov_e_->f, vlasov_i_->f, parameter_);
+  if (parameter_.bd_cond_phi[0].find("pp") != std::string::npos) {
+    real rho_average = poisson_->sum_rho_af(rho_);
+    real ncells_cg = 0.;
+    if (parameter_.dimensionality_x == 1)
+      ncells_cg = parameter_.size_x[0] - 1.;
+    if (parameter_.dimensionality_x == 2)
+      ncells_cg = (parameter_.size_x[0] - 1.) * (parameter_.size_x[1] - 1.);
+    if (parameter_.dimensionality_x == 3)
+      ncells_cg = (parameter_.size_x[0] - 1.) * (parameter_.size_x[1] - 1.) *
+                  (parameter_.size_x[2] - 1.);
+
+    rho_average = rho_average / ncells_cg;
+    rho_average =
+        boundary_.mpi_sum(rho_average) /
+        (parameter_.nproc[0] * parameter_.nproc[1] * parameter_.nproc[2]);
+
+    util::array_add_scalar(rho_, -rho_average, parameter_.ncellsAF_x);
+  }
+
+  // poisson
+  poisson_->conj_grad_start_af(rho_, residual_, conjugate_);
+  std::string orientation_phi[1] = {"ccc"};
+  boundary_.exchange_field_AF(conjugate_, parameter_.bd_cond_phi,
+                              orientation_phi, 1);
+  boundary_.exchange_field_border_AF(conjugate_, parameter_.bd_cond_phi,
+                                     orientation_phi, 1);
+
+  for (int i = 0; i < parameter_.cg_iterations; ++i) {
+
+    poisson_->conj_grad1_af(residual_, conjugate_, resres_, pAp_);
+    *resres_ = boundary_.mpi_sum(*resres_);
+    *pAp_ = boundary_.mpi_sum(*pAp_);
+
+    poisson_->conj_grad2_af(residual_, conjugate_, resres_, pAp_, beta_);
+    *resres_ = boundary_.mpi_sum(*resres_);
+
+    // exit criterion
+    real residual_norm = sqrt(*resres_);
+    if (residual_norm < parameter_.poisson_convergence_threshold) {
+
+      std::string orientation_phi[1] = {"ccc"};
+      boundary_.exchange_field_AF(poisson_->phi, parameter_.bd_cond_phi,
+                                  orientation_phi, 1);
+      boundary_.exchange_field_border_AF(poisson_->phi, parameter_.bd_cond_phi,
