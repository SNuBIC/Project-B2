+
+    invdx2 = 1._PRC/(dx*dx) 
+
+!   initialisation of residual and conjugate in calling routine
+!   residual(x,y,z) = rho(x,y,z) - (phi(x+1,y,z) -2._PRC*phi(x,y,z) + phi(x-1,y,z))*invdx2(1)
+!   conjugate = residual
+
+    if (dimensionality_x == 1) then
