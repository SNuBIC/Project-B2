+  species[kIon].ten_moment_k0 = 1./3. / sqrt(species[kIon].m);
+  gradient_closure_subcycles = 4; // rule of thumb: double subcycles when doubling the resolution
+  initial_maxwell_steps_per_fluid_step = 15;
