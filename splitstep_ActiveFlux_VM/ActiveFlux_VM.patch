+                                         model::Model *electromagnetic_model) {
+  // replace models when the scheme is changed
+}
+
+void VeViMAF::calc_alloc_converted_model(model::Model *&model_out, int species,
+                                         int target_scheme_id) {
+  // convert models when the scheme is changed
+}
+
+void VeViMAF::output(real t, int output_number, bool output_vtk) {
+  model::Model *plasma_models[2] = {vlasov_e_, vlasov_i_};
+  output_AF_allpoints::prepare_and_write(plasma_models, maxwell_, 2, t,
+                                         output_number, output_vtk, block_id_,
+                                         parameter_, electron_substep_counter_);
+}
