+                                                             -1._PRC/12._PRC*conjugate(x+2,y,z) -1._PRC/12._PRC*conjugate(x-2,y,z) )*invdx2(1) 
+                    end if
+                enddo
+            enddo
+        enddo
+
+
+    else if (dimensionality_x == 2) then
+ 
+        pAp=0._PRC
+        resres=0._PRC
+        do z=0,dimX(3)
+            do y=0,dimX(2)-1
+                do x=0,dimX(1)-1
+                    resres = resres + residual(x,y,z)*residual(x,y,z) 
+                    if (cg_order == 2) then
+                    pAp = pAp + conjugate(x,y,z) * (-1._PRC)*((conjugate(x+1,y,z) -2._PRC*conjugate(x,y,z) + conjugate(x-1,y,z))*invdx2(1) + &
+                                                              (conjugate(x,y+1,z) -2._PRC*conjugate(x,y,z) + conjugate(x,y-1,z))*invdx2(2))
+                    elseif (cg_order == 4) then
+                    pAp = pAp + conjugate(x,y,z) * (-1._PRC)*((4._PRC/3._PRC*conjugate(x+1,y,z) -5._PRC/2._PRC*conjugate(x,y,z) + 4._PRC/3._PRC*conjugate(x-1,y,z) &
+                                                             -1._PRC/12._PRC*conjugate(x+2,y,z) -1._PRC/12._PRC*conjugate(x-2,y,z))*invdx2(1) + &
+                                                              (4._PRC/3._PRC*conjugate(x,y+1,z) -5._PRC/2._PRC*conjugate(x,y,z) + 4._PRC/3._PRC*conjugate(x,y-1,z) &
+                                                             -1._PRC/12._PRC*conjugate(x,y+2,z) -1._PRC/12._PRC*conjugate(x,y-2,z) )*invdx2(2))
+                    end if
+                enddo
+            enddo
+        enddo
+
+    else ! dimensionality_x == 3
+
+        pAp=0._PRC
+        resres=0._PRC
+        do z=0,dimX(3)-1
+            do y=0,dimX(2)-1
+                do x=0,dimX(1)-1
+                    resres = resres + residual(x,y,z)*residual(x,y,z) 
+                    if (cg_order == 2) then
+                    pAp = pAp + conjugate(x,y,z) * (-1._PRC)*((conjugate(x+1,y,z) -2._PRC*conjugate(x,y,z) + conjugate(x-1,y,z))*invdx2(1) + &
+                                                              (conjugate(x,y+1,z) -2._PRC*conjugate(x,y,z) + conjugate(x,y-1,z))*invdx2(2) + &
+                                                              (conjugate(x,y,z+1) -2._PRC*conjugate(x,y,z) + conjugate(x,y,z-1))*invdx2(3))
+                    elseif (cg_order == 4) then
+                    pAp = pAp + conjugate(x,y,z) * (-1._PRC)*((4._PRC/3._PRC*conjugate(x+1,y,z) -5._PRC/2._PRC*conjugate(x,y,z) + 4._PRC/3._PRC*conjugate(x-1,y,z) &
+                                                             -1._PRC/12._PRC*conjugate(x+2,y,z) -1._PRC/12._PRC*conjugate(x-2,y,z))*invdx2(1) + &
+                                                              (4._PRC/3._PRC*conjugate(x,y+1,z) -5._PRC/2._PRC*conjugate(x,y,z) + 4._PRC/3._PRC*conjugate(x,y-1,z) &
+                                                             -1._PRC/12._PRC*conjugate(x,y+2,z) -1._PRC/12._PRC*conjugate(x,y-2,z))*invdx2(2) + &
+                                                              (4._PRC/3._PRC*conjugate(x,y,z+1) -5._PRC/2._PRC*conjugate(x,y,z) + 4._PRC/3._PRC*conjugate(x,y,z-1) &
+                                                             -1._PRC/12._PRC*conjugate(x,y,z+2) -1._PRC/12._PRC*conjugate(x,y,z-2))*invdx2(3))
+                    end if 
+                enddo
+            enddo
+        enddo
+    end if
+
+
+end subroutine poisson_conj_grad1_af
+
+subroutine poisson_conj_grad2_af(phi, residual, conjugate, dimX, BD, dx, dimensionality_x, cg_order, resres, pAp, beta)
+    use definitions
+    implicit none
+
+    integer, intent(in) :: dimX(3), BD(3), dimensionality_x
+    real(kind=PRC), intent(in) :: dx(3), cg_order
+    real(kind=PRC), intent(inout), dimension(-BD(1):dimX(1)+BD(1),-BD(2):dimX(2)+BD(2),-BD(3):dimX(3)+BD(3)) :: phi, residual, conjugate
+
+    integer :: x, y, z, zhi, yhi
+    real(kind=PRC) :: invdx2(3), pAp, alpha, beta
+    real(kind=PRC), intent(inout) :: resres
+
+    invdx2 = 1._PRC/(dx*dx) 
+
+
+        alpha = resres/pAp
+
+        
+        if (dimensionality_x == 1) then
+
+            zhi = dimX(3)
+            yhi = dimX(2)
+        do z=0,dimX(3)
+            do y=0,dimX(2)
+                do x=0,dimX(1)-1
+                    phi(x,y,z) = phi(x,y,z) + alpha*conjugate(x,y,z)
+                    if (cg_order == 2) then
+                    residual(x,y,z) = residual(x,y,z) - alpha*(-1._PRC)*(conjugate(x+1,y,z) -2._PRC*conjugate(x,y,z) + conjugate(x-1,y,z))*invdx2(1)
+                    elseif (cg_order == 4) then
+                    residual(x,y,z) = residual(x,y,z) - alpha*(-1._PRC)*(4._PRC/3._PRC*conjugate(x+1,y,z) -5._PRC/2._PRC*conjugate(x,y,z) + 4._PRC/3._PRC*conjugate(x-1,y,z)  &
+                                                              -1._PRC/12._PRC*conjugate(x+2,y,z) -1._PRC/12._PRC*conjugate(x-2,y,z) )*invdx2(1)
+                    end if
+                enddo
+            enddo
+        enddo
+
+        else if (dimensionality_x == 2) then
+
+            zhi = dimX(3)
+            yhi = dimX(2)-1
+        do z=0,dimX(3)
+            do y=0,dimX(2)-1
+                do x=0,dimX(1)-1
+                    phi(x,y,z) = phi(x,y,z) + alpha*conjugate(x,y,z)
+                    if (cg_order == 2) then
+                    residual(x,y,z) = residual(x,y,z) - alpha*(-1._PRC)*((conjugate(x+1,y,z) -2._PRC*conjugate(x,y,z) + conjugate(x-1,y,z))*invdx2(1) + &
+                                                                         (conjugate(x,y+1,z) -2._PRC*conjugate(x,y,z) + conjugate(x,y-1,z))*invdx2(2))
+                    elseif (cg_order == 4) then
+                    residual(x,y,z) = residual(x,y,z) - alpha*(-1._PRC)*((4._PRC/3._PRC*conjugate(x+1,y,z) -5._PRC/2._PRC*conjugate(x,y,z) + 4._PRC/3._PRC*conjugate(x-1,y,z) &
+                                                             -1._PRC/12._PRC*conjugate(x+2,y,z) -1._PRC/12._PRC*conjugate(x-2,y,z))*invdx2(1) + &
+                                                              (4._PRC/3._PRC*conjugate(x,y+1,z) -5._PRC/2._PRC*conjugate(x,y,z) + 4._PRC/3._PRC*conjugate(x,y-1,z) &
+                                                             -1._PRC/12._PRC*conjugate(x,y+2,z) -1._PRC/12._PRC*conjugate(x,y-2,z) )*invdx2(2))
+                    end if
+                enddo
+            enddo
+        enddo
+
+        else ! dimensionality_x == 3
+
+        zhi = dimX(3)-1
+        yhi = dimX(2)-1
+        do z=0,dimX(3)-1
+            do y=0,dimX(2)-1
+                do x=0,dimX(1)-1
+                    phi(x,y,z) = phi(x,y,z) + alpha*conjugate(x,y,z)
+                    if (cg_order == 2) then
+                    residual(x,y,z) = residual(x,y,z) - alpha*(-1._PRC)*((conjugate(x+1,y,z) -2._PRC*conjugate(x,y,z) + conjugate(x-1,y,z))*invdx2(1) + &
+                                                                         (conjugate(x,y+1,z) -2._PRC*conjugate(x,y,z) + conjugate(x,y-1,z))*invdx2(2) + &
+                                                                         (conjugate(x,y,z+1) -2._PRC*conjugate(x,y,z) + conjugate(x,y,z-1))*invdx2(3))
+                    elseif (cg_order == 4) then
+                    residual(x,y,z) = residual(x,y,z) - alpha*(-1._PRC)*((4._PRC/3._PRC*conjugate(x+1,y,z) -5._PRC/2._PRC*conjugate(x,y,z) + 4._PRC/3._PRC*conjugate(x-1,y,z) &
+                                                             -1._PRC/12._PRC*conjugate(x+2,y,z) -1._PRC/12._PRC*conjugate(x-2,y,z))*invdx2(1) + &
+                                                              (4._PRC/3._PRC*conjugate(x,y+1,z) -5._PRC/2._PRC*conjugate(x,y,z) + 4._PRC/3._PRC*conjugate(x,y-1,z) &
+                                                             -1._PRC/12._PRC*conjugate(x,y+2,z) -1._PRC/12._PRC*conjugate(x,y-2,z))*invdx2(2) + &
+                                                              (4._PRC/3._PRC*conjugate(x,y,z+1) -5._PRC/2._PRC*conjugate(x,y,z) + 4._PRC/3._PRC*conjugate(x,y,z-1) &
+                                                             -1._PRC/12._PRC*conjugate(x,y,z+2) -1._PRC/12._PRC*conjugate(x,y,z-2))*invdx2(3))
+                    end if
+                enddo
+            enddo
+        enddo
+        
+        end if 
+
+        beta = 1._PRC/resres
+        resres = 0._PRC
+        
+        do z=0,zhi
+            do y=0,yhi
+                do x=0,dimX(1)-1
+                    resres = resres + residual(x,y,z)*residual(x,y,z)
+                enddo
+            enddo
+        enddo
+ 
+
+end subroutine poisson_conj_grad2_af
+
+subroutine poisson_conj_grad3_af(residual, conjugate, dimX, BD, dimensionality_x, resres, beta)
+    use definitions
+    implicit none
+
+    integer, intent(in) :: dimX(3), BD(3), dimensionality_x
+   
+    real(kind=PRC), intent(inout), dimension(-BD(1):dimX(1)+BD(1),-BD(2):dimX(2)+BD(2),-BD(3):dimX(3)+BD(3)) :: residual, conjugate
+
+    integer :: x, y, z, zhi, yhi
+    real(kind=PRC) :: beta, resres
+
+    if (dimensionality_x == 1) then
+        zhi = 0
+        yhi = 0
+    elseif (dimensionality_x == 2) then
+        zhi = 0
+        yhi = dimX(2)-1
+    else
+        zhi = dimX(3)-1
+        yhi = dimX(2)-1
+    endif
+
+
+        beta = beta*resres
+        do z=0,zhi
+            do y=0,yhi
+                do x=0,dimX(1)-1
+                   conjugate(x,y,z) = residual(x,y,z) + beta*conjugate(x,y,z)
+                enddo
+            enddo
+        enddo
+        
+
+end subroutine poisson_conj_grad3_af
