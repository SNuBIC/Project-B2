+subroutine output_calc_statistics_fluid_af(n,u,T,m,mass,kinetic_energy,thermal_energy,&
+                momentum_x,momentum_y,momentum_z,dimX,BD,dx,dimensionality_x,dimensionality_v)
+    use definitions
+    implicit none
+
+    integer, intent(in) :: dimX(3), BD(3), dimensionality_x, dimensionality_v
+    real(kind=PRC), intent(in) :: dx(3), m
+    real(kind=PRC), intent(in), dimension(-BD(1):dimX(1)+BD(1),-BD(2):dimX(2)+BD(2),-BD(3):dimX(3)+BD(3)) :: n, T
+    real(kind=PRC), intent(in), dimension(-BD(1):dimX(1)+BD(1),-BD(2):dimX(2)+BD(2),-BD(3):dimX(3)+BD(3),3) :: u
+    real(kind=PRC), intent(out) :: mass, kinetic_energy, thermal_energy, momentum_x, momentum_y, momentum_z
+    
+    integer :: one(3)
+    real(kind=PRC) :: d3
+
+    one = 1
+    if (dimensionality_x < 3) one(3) = 0 ! start at 1 unless dummy dimension
+    if (dimensionality_x < 2) one(2) = 0
+
+    d3 = dx(1)
+    if (dimensionality_x > 1) d3 = d3*dx(2)
+    if (dimensionality_x > 2) d3 = d3*dx(3)
+
+    mass = m*sum(n(one(1):dimX(1):2,one(2):dimX(2):2,one(3):dimX(3):2))*d3
+    momentum_x = m*sum(u(one(1):dimX(1):2,one(2):dimX(2):2,one(3):dimX(3):2,1)*n(one(1):dimX(1):2,one(2):dimX(2):2,one(3):dimX(3):2))*d3
+    momentum_y = m*sum(u(one(1):dimX(1):2,one(2):dimX(2):2,one(3):dimX(3):2,2)*n(one(1):dimX(1):2,one(2):dimX(2):2,one(3):dimX(3):2))*d3
+    momentum_z = m*sum(u(one(1):dimX(1):2,one(2):dimX(2):2,one(3):dimX(3):2,3)*n(one(1):dimX(1):2,one(2):dimX(2):2,one(3):dimX(3):2))*d3
+    kinetic_energy = .5_PRC*m*sum(&
+                     (u(one(1):dimX(1):2,one(2):dimX(2):2,one(3):dimX(3):2,1)**2 + &
+                      u(one(1):dimX(1):2,one(2):dimX(2):2,one(3):dimX(3):2,2)**2 + &
+                      u(one(1):dimX(1):2,one(2):dimX(2):2,one(3):dimX(3):2,3)**2) * &
+                      n(one(1):dimX(1):2,one(2):dimX(2):2,one(3):dimX(3):2) &
+                      ) * d3
+    thermal_energy = .5_PRC*dimensionality_v*sum(T(one(1):dimX(1):2,one(2):dimX(2):2,one(3):dimX(3):2)*&
+                         n(one(1):dimX(1):2,one(2):dimX(2):2,one(3):dimX(3):2))*d3
+
+end subroutine output_calc_statistics_fluid_af
+
+
+subroutine output_calc_statistics_electromagnetic_af(E,B,eps0,mu0,electric_energy,magnetic_energy,&
+                          em_momentum_x,em_momentum_y,em_momentum_z,dimX,BD,dx,dimensionality_x)
+    use definitions
+    implicit none
+
+    integer, intent(in) :: dimX(3), BD(3), dimensionality_x
+    real(kind=PRC), intent(in) :: dx(3), eps0, mu0
+    real(kind=PRC), intent(in), dimension(-BD(1):dimX(1)+BD(1),-BD(2):dimX(2)+BD(2),-BD(3):dimX(3)+BD(3),3) :: E, B
+    real(kind=PRC), intent(out) :: electric_energy, magnetic_energy, em_momentum_x, em_momentum_y, em_momentum_z
+
+    integer :: one(3)
+    real(kind=PRC) :: d3
+    
+    one = 1
+    if (dimensionality_x < 3) one(3) = 0 ! exclude outermost point unless dummy dimension
+    if (dimensionality_x < 2) one(2) = 0
+
+    d3 = dx(1)
+    if (dimensionality_x > 1) d3 = d3*dx(2)
+    if (dimensionality_x > 2) d3 = d3*dx(3)
+
+    electric_energy = .5_PRC*eps0*sum(E(one(1):dimX(1):2,one(2):dimX(2):2,one(3):dimX(3):2,1)**2 + &
+                                      E(one(1):dimX(1):2,one(2):dimX(2):2,one(3):dimX(3):2,2)**2 + &
+                                      E(one(1):dimX(1):2,one(2):dimX(2):2,one(3):dimX(3):2,3)**2) * d3
+    magnetic_energy = .5_PRC/mu0 *sum(B(one(1):dimX(1):2,one(2):dimX(2):2,one(3):dimX(3):2,1)**2 + &
+                                      B(one(1):dimX(1):2,one(2):dimX(2):2,one(3):dimX(3):2,2)**2 + &
+                                      B(one(1):dimX(1):2,one(2):dimX(2):2,one(3):dimX(3):2,3)**2) * d3
+    em_momentum_x = eps0*sum(E(one(1):dimX(1):2,one(2):dimX(2):2,one(3):dimX(3):2,2)*B(one(1):dimX(1):2,one(2):dimX(2):2,one(3):dimX(3):2,3) - &
+                             E(one(1):dimX(1):2,one(2):dimX(2):2,one(3):dimX(3):2,3)*B(one(1):dimX(1):2,one(2):dimX(2):2,one(3):dimX(3):2,2))*d3
+    em_momentum_y = eps0*sum(E(one(1):dimX(1):2,one(2):dimX(2):2,one(3):dimX(3):2,3)*B(one(1):dimX(1):2,one(2):dimX(2):2,one(3):dimX(3):2,1) - &
+                             E(one(1):dimX(1):2,one(2):dimX(2):2,one(3):dimX(3):2,1)*B(one(1):dimX(1):2,one(2):dimX(2):2,one(3):dimX(3):2,3))*d3
+    em_momentum_z = eps0*sum(E(one(1):dimX(1):2,one(2):dimX(2):2,one(3):dimX(3):2,1)*B(one(1):dimX(1):2,one(2):dimX(2):2,one(3):dimX(3):2,2) - &
+                             E(one(1):dimX(1):2,one(2):dimX(2):2,one(3):dimX(3):2,2)*B(one(1):dimX(1):2,one(2):dimX(2):2,one(3):dimX(3):2,1))*d3
+
+end subroutine output_calc_statistics_electromagnetic_af
+
