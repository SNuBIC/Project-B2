+subroutine simpson_averaging_f(f, f_ave, sizex, sizev, BDAF, dimensionality_x, dimensionality_v)
+    use definitions
+    implicit none 
+    
+    integer, intent(in) :: sizex(3), sizev(3), BDAF(3), dimensionality_x, dimensionality_v
+    real(kind=PRC), intent(in), dimension(-BDAF(1):sizex(1)+BDAF(1),-BDAF(2):sizex(2)+BDAF(2),-BDAF(3):sizex(3)+BDAF(3),sizev(1),sizev(2),sizev(3)) :: f
+    real(kind=PRC), intent(inout), dimension(-BDAF(1):sizex(1)+BDAF(1),-BDAF(2):sizex(2)+BDAF(2),-BDAF(3):sizex(3)+BDAF(3),sizev(1),sizev(2),sizev(3)) :: f_ave
+    
+    integer :: x, y, z, vx, vy, vz
+    real(kind=PRC) :: sum_nodes, sum_edges, center
+    
+    ! only used for 1D convergence studies with DD
+  
+  !copy
+    f_ave(:,:,:,:,:,:) = f(:,:,:,:,:,:)
+    
+
+    if (dimensionality_x == 1 .and. dimensionality_v == 1) then
+    !centers
+
+       do vz = 1, sizev(3), 1 !dummy direction
+        do vy = 1, sizev(2), 1 !dummy direction
+         do vx = 2, sizev(1)-1, 2
+            do z = 0,sizex(3), 1 ! dummy direction
+                do y = 0,sizex(2), 1 ! dummy direction
+                    do x = 1, sizex(1)-1, 2
+                
+                 
+      
+      sum_nodes = f(x-1,y,z,vx-1,vy,vz) + f(x+1,y,z,vx-1,vy,vz) + f(x-1,y,z,vx+1,vy,vz) + f(x+1,y,z,vx+1,vy,vz)
+      sum_edges = f(x-1,y,z,vx,vy,vz) + f(x+1,y,z,vx,vy,vz) + f(x,y,z,vx-1,vy,vz) + f(x,y,z,vx+1,vy,vz)
+      center = f(x,y,z,vx,vy,vz)
+      
+      f_ave(x,y,z,vx,vy,vz) = (1./36.)*(sum_nodes + 4.*sum_edges + 16.*center)
+      
+    enddo
+    enddo
+    enddo
+    enddo
+    enddo
+    enddo
+endif
+    
+
+    
+  end subroutine simpson_averaging_f
