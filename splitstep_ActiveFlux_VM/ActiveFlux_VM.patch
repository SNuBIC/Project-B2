+                                            ((yVal - 0.5_PRC*dx(2) - 0.25_PRC*ysize)/lambda_y)**2) - &
+                                        (xVal - 0.5_PRC*dx(1) - 0.75_PRC*xsize)/lambda_x* &
+                                        exp(-((xVal - 0.75_PRC*xsize)/lambda_x)**2 - &
+                                            ((yVal - 0.5_PRC*dx(2) - 0.75_PRC*ysize)/lambda_y)**2))
