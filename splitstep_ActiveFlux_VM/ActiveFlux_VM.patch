+namespace scheme {
+// Vlasov electrons, Vlasov ions, Poisson
+
+class VeViPAF : public Scheme {
+public:
+  VeViPAF(const Block_id &block_id, Mpi_boundary &mpi_boundary,
+          const Parameter &parameter);
+  ~VeViPAF();
+
+  int get_scheme_id();
