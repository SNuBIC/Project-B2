+subroutine poisson_calc_div_E(E, divE, dimX, BD, dx) ! for Boris correction, face to center
+    use definitions
+    implicit none
+
+    integer, intent(in) :: dimX(3), BD(3)
+    real(kind=PRC), intent(in) :: dx(3)
+    real(kind=PRC), intent(in), dimension(-BD(1):dimX(1)+BD(1), -BD(2):dimX(2)+BD(2), -BD(3):dimX(3)+BD(3), 3) :: E
+    real(kind=PRC), intent(inout), dimension(-BD(1):dimX(1)+BD(1), -BD(2):dimX(2)+BD(2), -BD(3):dimX(3)+BD(3)) :: divE
+
+    integer :: x, y, z
+
+
+    do z = 0,dimX(3)
+        do y = 0,dimX(2)
+            do x = 0,dimX(1)
+                divE(x,y,z) = (E(x+1,y,z,1) - E(x,y,z,1)) / dx(1) + (E(x,y+1,z,2) - E(x,y,z,2)) / dx(2) + (E(x,y,z+1,3) - E(x,y,z,3)) / dx(3)
+            enddo
+        enddo
+    enddo
+end subroutine poisson_calc_div_E
+
+subroutine poisson_calc_div_B(B, divB, dimX, BD, dx) ! for Boris correction, edge to center
+    use definitions
+    implicit none
+
+    integer, intent(in) :: dimX(3), BD(3)
+    real(kind=PRC), intent(in) :: dx(3)
+    real(kind=PRC), intent(in), dimension(-BD(1):dimX(1)+BD(1), -BD(2):dimX(2)+BD(2), -BD(3):dimX(3)+BD(3), 3) :: B
+    real(kind=PRC), intent(inout), dimension(-BD(1):dimX(1)+BD(1), -BD(2):dimX(2)+BD(2), -BD(3):dimX(3)+BD(3)) :: divB
+
+    integer :: x, y, z
+
+
+    do z = 0,dimX(3)
+        do y = 0,dimX(2)
+            do x = 0,dimX(1)
+                divB(x,y,z) = (B(x,y,z,1) - B(x-1,y,z,1)) / dx(1) + (B(x,y,z,2) - B(x,y-1,z,2)) / dx(2) !+ (B(x,y,z,3) - B(x,y,z-1,3)) / dx(3)
+            enddo
+        enddo
+    enddo
+
+end subroutine poisson_calc_div_B
+
+
+subroutine poisson_calc_E_from_phi_fc(E, phi, dimX, BD, dx) ! deltaE = -grad(phi) for Boris correction, center to face
+    use definitions
+    implicit none
+
+    integer, intent(in) :: dimX(3), BD(3)
+    real(kind=PRC), intent(in) :: dx(3)
+    real(kind=PRC), intent(in   ), dimension(-BD(1):dimX(1)+BD(1), -BD(2):dimX(2)+BD(2), -BD(3):dimX(3)+BD(3)) :: phi
+    real(kind=PRC), intent(inout), dimension(-BD(1):dimX(1)+BD(1), -BD(2):dimX(2)+BD(2), -BD(3):dimX(3)+BD(3), 3) :: E
+
+    integer :: x, y, z
+
+    !$acc data present(E, phi)
+
+    !$acc parallel
+    !$acc loop gang
+    do z = 0,dimX(3)
+        !$acc loop vector collapse(2)
+        do y = 0,dimX(2)
+            do x = 0,dimX(1)
+                E(x,y,z,1) = (-phi(x,y,z) + phi(x-1,y,z)) / (dx(1))
+                E(x,y,z,2) = (-phi(x,y,z) + phi(x,y-1,z)) / (dx(2))
+                E(x,y,z,3) = (-phi(x,y,z) + phi(x,y,z-1)) / (dx(3))
+            enddo
+        enddo
+    enddo
+    !$acc end parallel
+
+    !$acc end data
+
