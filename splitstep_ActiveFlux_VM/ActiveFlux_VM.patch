+int Mpi_boundary::calc_buffer_size_AF(const int direction, const int ncomponents, const bool vspace, int species_id)
+{
+  int buffer_size = -1;
+
+  if (direction == p_.kXL || direction == p_.kXU)
+    buffer_size = ncomponents * p_.bdAF[0] * (p_.size_x[1] + 2*p_.bdAF[1]) * (p_.size_x[2] + 2*p_.bdAF[2]);
+  else if (direction == p_.kYL || direction == p_.kYU)
+    buffer_size = ncomponents * p_.bdAF[1] * (p_.size_x[0] + 2*p_.bdAF[0]) * (p_.size_x[2] + 2*p_.bdAF[2]);
+  else if (direction == p_.kZL || direction == p_.kZU)
+    buffer_size = ncomponents * p_.bdAF[2] * (p_.size_x[0] + 2*p_.bdAF[0]) * (p_.size_x[1] + 2*p_.bdAF[1]);
+
+  if (vspace && buffer_size != -1)
+    buffer_size *= p_.species[species_id].size_v[0]*p_.species[species_id].size_v[1]*p_.species[species_id].size_v[2];
+  
+  return buffer_size;
+}
