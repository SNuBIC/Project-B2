+  delete maxwell_;
+  delete vlasov_i_;
+  delete vlasov_e_;
+}
+
+int VeViMAF::get_scheme_id() { return parameter_.kVeViMAF; }
+
+real VeViMAF::get_dt(int species) {
+  if (species == Parameter::kIon) {
+    return dt_ * electron_substeps_;
+  }
+  return dt_;
+}
+
+int VeViMAF::get_data_size() {
+  // f_e (ncells_xv_e), f_i (ncells_xv_i)
+  // E (3*ncells), B (3*ncells), B_ipol (3*ncells), maxwell_dt (1),
+  // maxwell_subcycles (1)
+  return parameter_.species[parameter_.kElectron].ncellsAF_xv +
+         parameter_.species[parameter_.kIon].ncellsAF_xv +
+         9 * parameter_.ncellsAF_x + 2;
+}
+
+void VeViMAF::init() {
+
+  if (parameter_.restart) {
+    real scalars[3];
+    restart::load_scalars(scalars, parameter_.output_directory,
+                          block_id_.my_coords);
+    maxwell_->dt = scalars[0];
+    maxwell_->substeps = round(scalars[1]);
+    if (parameter_.electron_subcycling)
+      electron_substep_counter_ = round(scalars[2]);
+
+    restart::load_field(vlasov_e_->f, 0, parameter_.output_directory,
+                        block_id_.my_coords);
+    restart::load_field(vlasov_i_->f, 1, parameter_.output_directory,
+                        block_id_.my_coords);
+    restart::load_field(maxwell_->E, 2, parameter_.output_directory,
+                        block_id_.my_coords);
+    restart::load_field(maxwell_->B, 3, parameter_.output_directory,
+                        block_id_.my_coords);
+    restart::load_field(maxwell_->B_ipol, 4, parameter_.output_directory,
+                        block_id_.my_coords);
+#pragma acc update device(                                                     \
+    vlasov_e_->f [0:parameter_.species[parameter_.kElectron].ncellsAF_xv],     \
+    vlasov_i_->f [0:parameter_.species[parameter_.kIon].ncellAFs_xv],          \
+    maxwell_->E [0:3 * parameter_.ncellsAF_x],                                 \
+    maxwell_->B [0:3 * parameter_.ncellsAF_x],                                 \
+    maxwell_->B_ipol [0:3 * parameter_.ncellsAF_x])
+
+  } else {
+    // load setup
+    model::Model *plasma_models[2] = {vlasov_e_, vlasov_i_};
+    setupAF::init(plasma_models, maxwell_, parameter_);
+
+    // calc dt
+    dt_ = std::min(vlasov_e_->get_max_dt(), vlasov_i_->get_max_dt());
+    if (!parameter_.relax_fdtd_cfl)
+      dt_ = std::min(dt_, maxwell_->get_max_dt());
+    dt_ = boundary_.mpi_min(dt_);
+    maxwell_->dt =
+        std::min(maxwell_->get_max_dt(),
+                 dt_ / parameter_.initial_maxwell_steps_per_fluid_step);
+    maxwell_->substeps = floor(dt_ / maxwell_->dt);
+    maxwell_->substeps =
+        maxwell_->substeps - (maxwell_->substeps + 1) % 2; // force uneven
+
+    // calc j
+
+    convert::f_to_j_af(j_, vlasov_e_->f, vlasov_i_->f, parameter_);
+    std::string orientation_j[3] = {"ccc", "ccc", "ccc"};
+    boundary_.exchange_field_AF(j_, parameter_.bd_cond_v, orientation_j, 3);
+    ipol::yee_centered_to_face_AF(j_, j_fc_, parameter_);
+
+    if (parameter_.cweno_calc_j_from_flux) {
+      std::cerr
+          << std::endl
+          << "Warning: Parameter::cweno_calc_j_from_flux==true is not "
+          << "available with a pure Vlasov model. Set to false for coupling."
+          << std::endl
+          << std::endl;
+    }
+
+    // maxwell init step to get E to halftime
+    std::string orientation_E[3] = {"fcc", "cfc", "ccf"};
+    std::string orientation_B[3] = {"cff", "fcf", "ffc"};
+    std::string orientation_EB_cc[3] = {"ccc", "ccc", "ccc"};
+
+    maxwell_->step_E(0.5 * maxwell_->dt, j_fc_);
+    boundary_.exchange_field_AF(maxwell_->E, parameter_.bd_cond_E,
+                                orientation_E, 3);
+    for (int i = 0; i < maxwell_->substeps / 2; ++i) {
+      maxwell_->step_B(maxwell_->dt);
+      boundary_.exchange_field_AF(maxwell_->B, parameter_.bd_cond_B,
+                                  orientation_B, 3);
+      maxwell_->step_E(maxwell_->dt, j_fc_);
+      boundary_.exchange_field_AF(maxwell_->E, parameter_.bd_cond_E,
+                                  orientation_E, 3);
+    }
+    maxwell_->step_B_ipol(maxwell_->dt);
+    boundary_.exchange_field_AF(maxwell_->B, parameter_.bd_cond_B,
+                                orientation_B, 3);
+    boundary_.exchange_field_AF(maxwell_->B_ipol, parameter_.bd_cond_B,
+                                orientation_B, 3);
+  }
+  dt_ = maxwell_->substeps * maxwell_->dt;
+  if (parameter_.electron_subcycling) {
+    electron_substeps_ = std::max((int)(vlasov_i_->get_max_dt() / dt_), 1);
+    electron_substeps_ = boundary_.mpi_min(electron_substeps_);
+    electron_substeps_ =
+        electron_substeps_ - (electron_substeps_ + 1) % 2; // force uneven
+  }
+}
+
+void VeViMAF::step(int nsteps_total) {
+
+  ion_step_ = (electron_substep_counter_ == electron_substeps_ / 2);
+  real dt_i = dt_ * electron_substeps_;
+  if (parameter_.ion_step_vm == false)
+    ion_step_ = 0;
+
+  ipol::yee_face_to_centered_AF(maxwell_->E, E_cc_, parameter_);
+  ipol::yee_edge_to_centered_AF(maxwell_->B_ipol, B_cc_, parameter_);
+  // needed for Vlasov's first half-step v (TODO: only exchange for V-V and
+  // V-F10 neighbours)
+  std::string orientation_EB_cc[3] = {"ccc", "ccc", "ccc"};
+
+  boundary_.exchange_field_AF(E_cc_, parameter_.bd_cond_E, orientation_EB_cc,
+                              3);
+  boundary_.exchange_field_AF(B_cc_, parameter_.bd_cond_B, orientation_EB_cc,
+                              3);
+
+  // calc rho(t0) for Boris correction (in case of restart compute explicitly)
+  convert::f_to_rho_af(rhoold_, vlasov_e_->f, vlasov_i_->f, parameter_);
+
+  std::string orientation_rhoold[1] = {"ccc"};
+  boundary_.exchange_field_AF(rhoold_, parameter_.bd_cond_n, orientation_rhoold,
+                              1);
+
+  // vlasov using E(t1/2) uncorrected
+  // half step v
+  // Strang splitting
+
+  if (parameter_.dimensionality_v > 2) { // 0.5 z
+    vlasov_e_->step_vz(dt_ * 0.5 * 0.5, *E_cc_, *B_cc_,
+                       include_boundary_cells_);
+    if (ion_step_)
+      vlasov_i_->step_vz(dt_i * 0.5 * 0.5, *E_cc_, *B_cc_,
+                         include_boundary_cells_);
+  }
+  if (parameter_.dimensionality_v > 1) { // 0.5 y
+    vlasov_e_->step_vy(dt_ * 0.5 * 0.5, *E_cc_, *B_cc_,
+                       include_boundary_cells_);
+    if (ion_step_)
+      vlasov_i_->step_vy(dt_i * 0.5 * 0.5, *E_cc_, *B_cc_,
+                         include_boundary_cells_);
+  }
+  vlasov_e_->step_vx(dt_ * 0.5, *E_cc_, *B_cc_,
+                     include_boundary_cells_); // 1. x
+  if (ion_step_)
+    vlasov_i_->step_vx(dt_i * 0.5, *E_cc_, *B_cc_, include_boundary_cells_);
+  if (parameter_.dimensionality_v > 1) { // 0.5 y
+    vlasov_e_->step_vy(dt_ * 0.5 * 0.5, *E_cc_, *B_cc_,
+                       include_boundary_cells_);
+    if (ion_step_)
+      vlasov_i_->step_vy(dt_i * 0.5 * 0.5, *E_cc_, *B_cc_,
+                         include_boundary_cells_);
+  }
+  if (parameter_.dimensionality_v > 2) { // 0.5 z
+    vlasov_e_->step_vz(dt_ * 0.5 * 0.5, *E_cc_, *B_cc_,
+                       include_boundary_cells_);
+    if (ion_step_)
+      vlasov_i_->step_vz(dt_i * 0.5 * 0.5, *E_cc_, *B_cc_,
+                         include_boundary_cells_);
+  }
+
+  // step x
+  vlasov_e_->step_x(dt_);
+  if (ion_step_)
+    vlasov_i_->step_x(dt_i);
+  if (parameter_.dimensionality_x > 1) {
+    vlasov_e_->step_y(dt_);
+    if (ion_step_)
+      vlasov_i_->step_y(dt_i);
+  }
+  if (parameter_.dimensionality_x > 2) {
+    vlasov_e_->step_z(dt_);
+    if (ion_step_)
+      vlasov_i_->step_z(dt_i);
+  }
+
+  // second half step v
+  // Strang splitting
+
+  if (parameter_.dimensionality_v > 2) { // 0.5 z
+    vlasov_e_->step_vz(dt_ * 0.5 * 0.5, *E_cc_, *B_cc_);
+    if (ion_step_)
+      vlasov_i_->step_vz(dt_i * 0.5 * 0.5, *E_cc_, *B_cc_);
+  }
+  if (parameter_.dimensionality_v > 1) { // 0.5 y
+    vlasov_e_->step_vy(dt_ * 0.5 * 0.5, *E_cc_, *B_cc_);
+    if (ion_step_)
+      vlasov_i_->step_vy(dt_i * 0.5 * 0.5, *E_cc_, *B_cc_);
+  }
+  vlasov_e_->step_vx(dt_ * 0.5, *E_cc_, *B_cc_); // 1. x
+  if (ion_step_)
+    vlasov_i_->step_vx(dt_i * 0.5, *E_cc_, *B_cc_);
+  if (parameter_.dimensionality_v > 1) { // 0.5 y
+    vlasov_e_->step_vy(dt_ * 0.5 * 0.5, *E_cc_, *B_cc_);
+    if (ion_step_)
+      vlasov_i_->step_vy(dt_i * 0.5 * 0.5, *E_cc_, *B_cc_);
+  }
+  if (parameter_.dimensionality_v > 2) { // 0.5 z
+    vlasov_e_->step_vz(dt_ * 0.5 * 0.5, *E_cc_, *B_cc_);
+    if (ion_step_)
+      vlasov_i_->step_vz(dt_i * 0.5 * 0.5, *E_cc_, *B_cc_);
+  }
+
+  exchange_plasma_solvers(vlasov_e_->f, vlasov_i_->f);
+
+  // calc j
+
+  convert::f_to_j_af(j_, vlasov_e_->f, vlasov_i_->f, parameter_);
+  std::string orientation_j[3] = {"ccc", "ccc", "ccc"};
+  boundary_.exchange_field_AF(j_, parameter_.bd_cond_v, orientation_j, 3);
+
+  ipol::yee_centered_to_face_AF(j_, j_fc_, parameter_);
+
+  electron_substep_counter_++;
+
+  // update dt
+  int substeps_maxwell_old =
+      maxwell_->substeps; // for change of maxwell subcycles
+
+  if (!parameter_.freeze_dt &&
+      electron_substep_counter_ == electron_substeps_) {
+    electron_substep_counter_ = 0;
+    dt_ = std::min(vlasov_e_->get_max_dt(), vlasov_i_->get_max_dt());
+    if (!parameter_.relax_fdtd_cfl)
+      dt_ = std::min(dt_, maxwell_->get_max_dt());
+    dt_ = boundary_.mpi_min(dt_);
+    maxwell_->substeps = floor(dt_ / maxwell_->dt);
+    maxwell_->substeps =
+        maxwell_->substeps - (maxwell_->substeps + 1) % 2; // force uneven
+    dt_ = maxwell_->substeps * maxwell_->dt;
+    if (maxwell_->substeps <= 0) {
+      std::cerr << std::endl
+                << "Error: dt_fluid < dt_maxwell not allowed, adjust "
+                << "parameter::initial_maxwell_steps_per_fluid_step or check "
+                << "numerical stability!" << std::endl;
+      std::exit(EXIT_FAILURE);
+    }
+    if (parameter_.electron_subcycling) {
+      electron_substeps_ = std::max((int)(vlasov_i_->get_max_dt() / dt_), 1);
+      electron_substeps_ = boundary_.mpi_min(electron_substeps_);
+      electron_substeps_ =
+          electron_substeps_ - (electron_substeps_ + 1) % 2; // force uneven
+    }
+  }
+
+  // Boris correction of E(t1/2)
+
+  // calc rho(t1/2) by averaging rhoold and rho
+  convert::f_to_rho_af(rho_, vlasov_e_->f, vlasov_i_->f, parameter_);
+  util::add_arrays(rho_, rho_, rhoold_, 0.5, 0.5, parameter_.ncellsAF_x);
+
+  // store rhohalf in rhoold for later
+  std::copy(rho_, rho_ + parameter_.ncellsAF_x, rhoold_);
+
+  // calc divE(t1/2) at cell centers
+  poisson_->calc_div_E(maxwell_->E, divE_);
+
+  // calc rhs, store in rho
+  util::add_arrays(rho_, rho_, divE_, 1. / parameter_.eps0, -1.,
+                   parameter_.ncellsAF_x);
+
+  std::string orientation_rho[1] = {"ccc"};
+  boundary_.exchange_field_AF(rho_, parameter_.bd_cond_n, orientation_rho, 1);
+
+  // subtract ave
+
+  real rho_average = poisson_->sum_rho_af(rho_); // leaves out rightmost points
+  real ncells_cg = 0.;
+  if (parameter_.dimensionality_x == 1)
+    ncells_cg = parameter_.size_x[0] - 1.;
+  if (parameter_.dimensionality_x == 2)
+    ncells_cg = (parameter_.size_x[0] - 1.) * (parameter_.size_x[1] - 1.);
+  if (parameter_.dimensionality_x == 3)
+    ncells_cg = (parameter_.size_x[0] - 1.) * (parameter_.size_x[1] - 1.) *
+                (parameter_.size_x[2] - 1.);
+
+  rho_average = rho_average / ncells_cg;
+  rho_average =
+      boundary_.mpi_sum(rho_average) /
+      (parameter_.nproc[0] * parameter_.nproc[1] * parameter_.nproc[2]);
+  util::array_add_scalar(rho_, -rho_average, parameter_.ncellsAF_x);
+
+  // CG to solve for delta phi, calc deltaE from phi
+
+  poisson_->conj_grad_start_af(rho_, residual_, conjugate_);
+  std::string orientation_phi[1] = {"ccc"};
+  boundary_.exchange_field_AF(conjugate_, parameter_.bd_cond_phi,
+                              orientation_phi, 1);
+  boundary_.exchange_field_border_AF(conjugate_, parameter_.bd_cond_phi,
+                                     orientation_phi, 1);
+  for (int i = 0; i < parameter_.cg_iterations; ++i) {
+    poisson_->conj_grad1_af(residual_, conjugate_, resres_, pAp_);
+    *resres_ = boundary_.mpi_sum(*resres_);
+    *pAp_ = boundary_.mpi_sum(*pAp_);
+    poisson_->conj_grad2_af(residual_, conjugate_, resres_, pAp_, beta_);
+    *resres_ = boundary_.mpi_sum(*resres_);
+    // exit criterion
+    real residual_norm = sqrt(*resres_);
+    if (residual_norm < parameter_.poisson_convergence_threshold) {
+      std::string orientation_phi[1] = {"ccc"};
+      boundary_.exchange_field_AF(poisson_->phi, parameter_.bd_cond_phi,
+                                  orientation_phi, 1);
+      boundary_.exchange_field_border_AF(poisson_->phi, parameter_.bd_cond_phi,
+                                         orientation_phi, 1);
+      break;
+    }
+
+    poisson_->conj_grad3_af(residual_, conjugate_, resres_, beta_);
+
+    std::string orientation_phi[1] = {"ccc"};
+    boundary_.exchange_field_AF(conjugate_, parameter_.bd_cond_phi,
+                                orientation_phi, 1);
+    boundary_.exchange_field_border_AF(conjugate_, parameter_.bd_cond_phi,
+                                       orientation_phi, 1);
+  }
+
+  poisson_
+      ->calc_E_from_phi_fc(); // get face centered E, unlike in Poisson scheme
+  std::string orientation_E[3] = {"fcc", "cfc", "ccf"};
+
+  // add Poisson deltaE to Maxwell E(t1/2)
+  util::array_add_equal(maxwell_->E, poisson_->E, 3 * parameter_.ncellsAF_x);
+  boundary_.exchange_field_AF(maxwell_->E, parameter_.bd_cond_E, orientation_E,
+                              3);
+
+  // end Boris correction
+  // write Gauss error to file
+
+  if (nsteps_total % 1000 == 0) {
+    double current_time = nsteps_total * dt_i;
+
+    // calc divE_corr at cell centers
+    poisson_->calc_div_E(maxwell_->E, divE_);
+    poisson_->calc_div_B(maxwell_->B, divB_);
+    boundary_.exchange_field_AF(divE_, parameter_.bd_cond_E, orientation_rho,
+                                1);
+    boundary_.exchange_field_AF(divB_, parameter_.bd_cond_E, orientation_rho,
+                                1);
+
+    // calc error, store in rhoold
+    util::add_arrays(rhoold_, rhoold_, divE_, 1. / parameter_.eps0, -1.,
+                     parameter_.ncellsAF_x);
+    boundary_.exchange_field_AF(rhoold_, parameter_.bd_cond_n, orientation_rho,
+                                1);
+
+    auto max_norm_ptr_E = std::max_element(
+        rhoold_, rhoold_ + parameter_.ncellsAF_x,
+        [](double a, double b) { return std::abs(a) < std::abs(b); });
+
+    double local_max_divE = std::abs(*max_norm_ptr_E);
+    double global_max_divE = boundary_.mpi_max(local_max_divE);
+
+    auto max_norm_ptr_B = std::max_element(
+        divB_, divB_ + parameter_.ncellsAF_x,
+        [](double a, double b) { return std::abs(a) < std::abs(b); });
+
+    double local_max_divB = std::abs(*max_norm_ptr_B);
+    double global_max_divB = boundary_.mpi_max(local_max_divB);
+
+    if (block_id_.my_id == 0) {
+      std::ofstream error_file(parameter_.output_directory + "/div_error.dat",
+                               std::ios::out | std::ios::app);
+
+      if (error_file.is_open()) {
+        if (error_file.tellp() == 0) {
+          error_file << "# " << std::setw(13) << "time" << std::setw(12)
+                     << "step" << std::setw(25) << "divE max" << std::setw(25)
+                     << "divB max"
+                     << "\n";
+        }
+
+        error_file << std::scientific << std::setprecision(8) << std::setw(15)
+                   << current_time << std::fixed << " " << std::setprecision(0)
+                   << std::setw(12) << nsteps_total << std::scientific << " "
+                   << std::setprecision(15) << std::setw(25) << global_max_divE
+                   << std::scientific << " " << std::setprecision(15)
+                   << std::setw(25) << global_max_divB << "\n";
+
+        error_file.close();
+      }
+    }
+  }
+
+  // maxwell to get E(t3/2) using the corrected E(t1/2) and j(t1/2) resulting
+  // from the v-update using the uncorrected E(t1/2)
+  std::string orientation_B[3] = {"cff", "fcf", "ffc"};
+  maxwell_->step_E(maxwell_->dt, j_fc_);
+
+  boundary_.exchange_field_AF(maxwell_->E, parameter_.bd_cond_E, orientation_E,
+                              3);
+
+  for (int i = 0; i < (substeps_maxwell_old + maxwell_->substeps) / 2 - 1;
+       ++i) {
+    maxwell_->step_B(maxwell_->dt);
+    boundary_.exchange_field_AF(maxwell_->B, parameter_.bd_cond_B,
+                                orientation_B, 3);
+    maxwell_->step_E(maxwell_->dt, j_fc_);
+    boundary_.exchange_field_AF(maxwell_->E, parameter_.bd_cond_E,
+                                orientation_E, 3);
+  }
+  maxwell_->step_B_ipol(maxwell_->dt);
+
+  boundary_.exchange_field_AF(maxwell_->B, parameter_.bd_cond_B, orientation_B,
+                              3);
+  boundary_.exchange_field_AF(maxwell_->B_ipol, parameter_.bd_cond_B,
+                              orientation_B, 3);
+}
+
+void VeViMAF::exchange_plasma_solvers(real *data_e, real *data_i) {
+
+  real *buffer_out_e[parameter_.kNDirections],
+      *buffer_out_i[parameter_.kNDirections],
+      *buffer_in_e[parameter_.kNDirections],
+      *buffer_in_i[parameter_.kNDirections];
+  int buffer_size_e[parameter_.kNDirections],
+      buffer_size_i[parameter_.kNDirections];
+
+  std::string orientation[1] = {"ccc"};
+
+  bool exchange_this_direction_e[6] = {0, 0, 0, 0, 0, 0};
+  bool exchange_this_direction_i[6] = {0, 0, 0, 0, 0, 0};
+
+  for (int d = 0; d < parameter_.kNDirections; ++d) {
+
+    // prepare buffers
+    if (block_id_.neighbour_scheme_ids[d] == parameter_.kVeViMAF) {
+      // electrons
+      exchange_this_direction_e[d] = true;
+      buffer_size_e[d] =
+          boundary_.calc_buffer_size_AF(d, 1, true, parameter_.kElectron);
+      buffer_out_e[d] = new real[buffer_size_e[d]];
+      buffer_in_e[d] = new real[buffer_size_e[d]];
+#pragma acc enter data create(buffer_out_e [d:1] [0:buffer_size_e[d]],         \
+                              buffer_in_e [d:1] [0:buffer_size_e[d]])
+      boundary_.extract_buffer_AF(data_e, buffer_out_e[d], d, 1, true,
+                                  parameter_.kElectron);
+      // ions
+      if (ion_step_) {
+        exchange_this_direction_i[d] = true;
+        buffer_size_i[d] =
+            boundary_.calc_buffer_size_AF(d, 1, true, parameter_.kIon);
+        buffer_out_i[d] = new real[buffer_size_i[d]];
+        buffer_in_i[d] = new real[buffer_size_i[d]];
+#pragma acc enter data create(buffer_out_i [d:1] [0:buffer_size_i[d]],         \
+                              buffer_in_i [d:1] [0:buffer_size_i[d]])
+        boundary_.extract_buffer_AF(data_i, buffer_out_i[d], d, 1, true,
+                                    parameter_.kIon);
+      }
+    }
+  }
+
+  // send/receive buffers
+  for (int d = 0; d < parameter_.kNDirections; ++d) {
+    if (exchange_this_direction_e[d])
+      boundary_.exchange_buffer(buffer_out_e[d], buffer_in_e[d],
+                                buffer_size_e[d], d);
+  }
+  boundary_.wait(exchange_this_direction_e);
+  for (int d = 0; d < parameter_.kNDirections; ++d) {
+    if (exchange_this_direction_i[d])
+      boundary_.exchange_buffer(buffer_out_i[d], buffer_in_i[d],
+                                buffer_size_i[d], d);
+  }
+  boundary_.wait(exchange_this_direction_i);
+
+  for (int d = 0; d < parameter_.kNDirections; ++d) {
+
+    // apply received buffers (convert if necessary)
+    if (block_id_.neighbour_scheme_ids[d] == parameter_.kVeViMAF) {
+      // electrons
+      boundary_.apply_buffer_AF(data_e, buffer_in_e[d], d, 1, true,
+                                parameter_.kElectron);
+      // ions
+      if (ion_step_) {
+        boundary_.apply_buffer_AF(data_i, buffer_in_i[d], d, 1, true,
+                                  parameter_.kIon);
+      }
+    }
+
+    // clean up
+    if (exchange_this_direction_e[d]) {
+#pragma acc exit data delete (buffer_out_e [d:1] [0:buffer_size_e[d]],         \
+                              buffer_in_e [d:1] [0:buffer_size_e[d]])
+      delete[] buffer_out_e[d];
+      delete[] buffer_in_e[d];
+    }
+    if (exchange_this_direction_i[d]) {
+#pragma acc exit data delete (buffer_out_i [d:1] [0:buffer_size_i[d]],         \
+                              buffer_in_i [d:1] [0:buffer_size_i[d]])
+      delete[] buffer_out_i[d];
+      delete[] buffer_in_i[d];
+    }
+
+    // apply boundary conditions
+    boundary_.apply_boundary_conditions_AF(data_e, parameter_.bd_cond_v,
+                                           orientation, d, 1, true,
+                                           parameter_.kElectron);
+    if (ion_step_) {
+      boundary_.apply_boundary_conditions_AF(data_i, parameter_.bd_cond_v,
+                                             orientation, d, 1, true,
+                                             parameter_.kIon);
+    }
+  }
+}
+
+void VeViMAF::send_model_data(real *out_buffer, int receiver_id) {
+
+  model::Model *plasma_models[2] = {vlasov_e_, vlasov_i_};
+  load_balancing::send_model_data(out_buffer, get_data_size(), plasma_models,
+                                  maxwell_, 2, receiver_id, boundary_,
+                                  parameter_);
+}
+
+void VeViMAF::receive_model_data(real *in_buffer, int sender_id) {
+
+  model::Model *plasma_models[2] = {vlasov_e_, vlasov_i_};
+  load_balancing::receive_model_data(in_buffer, get_data_size(), plasma_models,
+                                     maxwell_, 2, sender_id, boundary_,
+                                     parameter_);
+}
