+subroutine stepx_vlasov_af(fs, sizex, sizev, BD, dt, dx, dv, vb, direction, dimensionality_x)
+   use definitions
+   implicit none
+
+   integer :: sizex(3), sizev(3), BD(3), direction, dimensionality_x
+   real(kind=PRC) :: dx(3), dv(3), dt, vb(3)
+
+   real(kind=PRC) , dimension(-BD(1):sizex(1)+BD(1), -BD(2):sizex(2)+BD(2), -BD(3):sizex(3)+BD(3), sizev(1), sizev(2), sizev(3)) :: fs
+
+   integer :: ix, iy, iz, ivx, ivy, ivz, BDY, BDZ
+   real(kind=PRC)  :: a, dt_dx
+   real(kind=PRC), dimension(:), allocatable :: f
+
+   a = 0._PRC
+
+   if (direction .eq. 1) then
+
+      dt_dx = dt/dx(1)
+
+      allocate (f(-BD(1):sizex(1) + BD(1)))
+
+      BDY = 0
+      BDZ = 0
+      if (dimensionality_x > 1) BDY = BD(2)
+      if (dimensionality_x > 2) BDZ = BD(3)
+
+      do ivz = 1, sizev(3)
+      do ivy = 1, sizev(2)
+      do ivx = 1, sizev(1)
+
+         a = dt_dx*(vb(1) + 0.5_PRC*dv(1)*(ivx - 1))
+
+         do iz = -BDZ, sizex(3) + BDZ
+         do iy = -BDY, sizex(2) + BDY
+
+            f(:) = fs(:, iy, iz, ivx, ivy, ivz)
+
+            call advection_super_simple(f, sizex(1), BD(1), a)
+
+            fs(:, iy, iz, ivx, ivy, ivz) = f(:)
+
+         end do
+         end do
+
+      end do
+      end do
+      end do
+      deallocate (f)
+
+   else if (direction .eq. 2) then
+
+      dt_dx = dt/dx(2)
+
+      allocate (f(-BD(2):sizex(2) + BD(2)))
+
+      BDZ = 0
+      if (dimensionality_x > 2) BDZ = BD(3)
+
+      do ivz = 1, sizev(3)
+      do ivy = 1, sizev(2)
+      do ivx = 1, sizev(1)
+
+         if (sizev(2) > 1) a = dt_dx*(vb(2) + 0.5_PRC*dv(2)*(ivy - 1))
+         if (sizev(2) == 1) a = dt_dx*(vb(2) + 0.5_PRC*dv(2)*(ivy - 1) + 0.5_PRC*dv(2))
+
+         do iz = -BDZ, sizex(3) + BDZ
+         do ix = 0, sizex(1)
+
+            f(:) = fs(ix, :, iz, ivx, ivy, ivz)
+
+            call advection_super_simple(f, sizex(2), BD(2), a)
+
+            fs(ix, :, iz, ivx, ivy, ivz) = f(:)
+
+         end do
+         end do
+
+      end do
+      end do
+      end do
+
+      deallocate (f)
+
+   else if (direction .eq. 3) then
+      dt_dx = dt/dx(3)
+
+      allocate (f(-BD(3):sizex(3) + BD(3)))
+
+      do ivz = 1, sizev(3)
+      do ivy = 1, sizev(2)
+      do ivx = 1, sizev(1)
+
+         if (sizev(3) > 1) a = dt_dx*(vb(3) + 0.5_PRC*dv(3)*(ivz - 1))
+         if (sizev(3) == 1) a = dt_dx*(vb(3) + 0.5_PRC*dv(3)*(ivz - 1) + 0.5_PRC*dv(3))
+
+         do iy = 0, sizex(2)
+         do ix = 0, sizex(1)
+
+            f(:) = fs(ix, iy, :, ivx, ivy, ivz)
+
+            call advection_super_simple(f, sizex(3), BD(3), a)
+
+            fs(ix, iy, :, ivx, ivy, ivz) = f(:)
+
+         end do
+         end do
+
+      end do
+      end do
+      end do
+
+      deallocate (f)
+
+   end if
+
+end subroutine stepx_vlasov_af
+
+subroutine stepv_vlasov_af(fs, E, B, sizex, sizev, BD, dt, dv, vb, qs, ms, direction, dimensionality_x, include_boundary_cells)
+   use definitions
+   implicit none
+
+   integer :: sizex(3), sizev(3), BD(3), direction, dimensionality_x
+   real(kind=PRC)  :: dv(3), dt, vb(3)
+   real(kind=PRC)  :: ms, qs
+   logical, intent(in) :: include_boundary_cells
+   real(kind=PRC) , dimension(-BD(1):sizex(1)+BD(1),-BD(2):sizex(2)+BD(2),-BD(3):sizex(3)+BD(3), sizev(1), sizev(2), sizev(3)) :: fs
+   real(kind=PRC), dimension(-BD(1):sizex(1) + BD(1), -BD(2):sizex(2) + BD(2), -BD(3):sizex(3) + BD(3), 3) :: E, B
+
+   integer :: ix, iy, iz, ivx, ivy, ivz, BDX, BDY, BDZ
+   real(kind=PRC)  :: a, vx, vy, vz, qmd
+
+   real(kind=PRC), dimension(:), allocatable :: f
+
+   vx = 0._PRC
+   vy = 0._PRC
+   vz = 0._PRC
+
+   BDX = 0
+   BDY = 0
+   BDZ = 0
+   if (include_boundary_cells) then
+      BDX = BD(1)
+      if (dimensionality_x > 1) BDY = BD(2)
+      if (dimensionality_x > 2) BDZ = BD(3)
+   end if
+
+   if (direction .eq. 1) then
+
+      qmd = dt*qs/ms/dv(1)
+
+      allocate (f(sizev(1)))
+
+      do ivz = 1, sizev(3)
+      do ivy = 1, sizev(2)
+         do iz = -BDZ, sizex(3) + BDZ
+            do iy = -BDY, sizex(2) + BDY
+            do ix = -BDX, sizex(1) + BDX
+
+               if (sizev(2) > 1) vy = vb(2) + 0.5_PRC*dv(2)*(ivy - 1)
+               if (sizev(2) == 1) vy = vb(2) + 0.5_PRC*dv(2)*(ivy - 1) + 0.5_PRC*dv(2)
+               if (sizev(3) > 1) vz = vb(3) + 0.5_PRC*dv(3)*(ivz - 1)
+               if (sizev(3) == 1) vz = vb(3) + 0.5_PRC*dv(3)*(ivz - 1) + 0.5_PRC*dv(3)
+
+               a = qmd*(E(ix, iy, iz, 1) + vy*B(ix, iy, iz, 3) - vz*B(ix, iy, iz, 2))
+
+               f(:) = fs(ix, iy, iz, :, ivy, ivz)
+
+               call advection_super_simplev(f, sizev(1) - 1, 0, a)
+
+               fs(ix, iy, iz, :, ivy, ivz) = f(:)
+
+            end do
+            end do
+         end do
+      end do
+      end do
+
+      deallocate (f)
+
+   else if (direction .eq. 2) then
+      qmd = dt*qs/ms/dv(2)
+
+      allocate (f(sizev(2)))
+
+      do ivz = 1, sizev(3)
+      do ivx = 1, sizev(1)
+         do iz = -BDZ, sizex(3) + BDZ
+            do iy = -BDY, sizex(2) + BDY
+            do ix = -BDX, sizex(1) + BDX
+
+               vx = vb(1) + 0.5_PRC*dv(1)*(ivx - 1)
+
+               if (sizev(3) > 1) vz = vb(3) + 0.5_PRC*dv(3)*(ivz - 1)
+               if (sizev(3) == 1) vz = vb(3) + 0.5_PRC*dv(3)*(ivz - 1) + 0.5_PRC*dv(3)
+
+               a = qmd*(E(ix, iy, iz, 2) + vz*B(ix, iy, iz, 1) - vx*B(ix, iy, iz, 3))
+
+               f(:) = fs(ix, iy, iz, ivx, :, ivz)
+
+               call advection_super_simplev(f, sizev(2) - 1, 0, a)
+
+               fs(ix, iy, iz, ivx, :, ivz) = f(:)
+
+            end do
+            end do
+         end do
+      end do
+      end do
+
+      deallocate (f)
+
+   else if (direction .eq. 3) then
+      qmd = dt*qs/ms/dv(3)
+      allocate (f(sizev(3)))
+
+      do ivy = 1, sizev(2)
+      do ivx = 1, sizev(1)
+         do iz = -BDZ, sizex(3) + BDZ
+            do iy = -BDY, sizex(2) + BDY
+            do ix = -BDX, sizex(1) + BDX
+
+               vx = vb(1) + 0.5_PRC*dv(1)*(ivx - 1)
+               if (sizev(2) > 1) vy = vb(2) + 0.5_PRC*dv(2)*(ivy - 1)
+               if (sizev(2) == 1) vy = vb(2) + 0.5_PRC*dv(2)*(ivy - 1) + 0.5_PRC*dv(2)
+               a = qmd*(E(ix, iy, iz, 3) + vx*B(ix, iy, iz, 2) - vy*B(ix, iy, iz, 1))
+
+               f(:) = fs(ix, iy, iz, ivx, ivy, :)
+
+               call advection_super_simplev(f, sizev(3) - 1, 0, a)
+
+               fs(ix, iy, iz, ivx, ivy, :) = f(:)
+
+            end do
+            end do
+         end do
+      end do
+      end do
+
+      deallocate (f)
+
+   end if
+
+end subroutine stepv_vlasov_af
+
+subroutine advection_super_simple(u, sizex, BD, speed)
+   use definitions
+   implicit none
+
+   integer :: sizex, BD
+   real(kind=PRC) :: speed
+   real(kind=PRC) :: u(-BD:sizex + BD)
+
+   integer :: i
+   real(kind=PRC) :: nu
+   real(kind=PRC), dimension(-BD:sizex + BD) :: uold
+
+   uold(:) = u(:)
+
+   !evolution
+   nu = abs(speed) !CFL, speed is actually speed*dt/dx
+
+   !positive advection velocity
+   if (speed >= 0._PRC) then
+
+      !interface update formula
+      do i = 0, sizex, 2
+
+         u(i) = nu*(3._PRC*nu - 2._PRC)*uold(i - 2) &
+                + 6._PRC*nu*(1._PRC - nu)*uold(i - 1) &
+                + (1._PRC - nu)*(1._PRC - 3._PRC*nu)*uold(i)
+
+      end do
+
+      !average update formula
+      do i = 1, sizex - 1, 2
+
+         u(i) = nu**2*(nu - 1._PRC)*uold(i - 3) &
+                + nu**2*(3._PRC - 2._PRC*nu)*uold(i - 2) &
+                + nu*(1._PRC - nu)*uold(i - 1) &
+                + (1._PRC - nu)**2*(1._PRC + 2._PRC*nu)*uold(i) &
+                - nu*(1._PRC - nu)**2*uold(i + 1)
+
+      end do
+
+      !negative advection velocity
+   else if (speed < 0._PRC) then
+
+      do i = 0, sizex, 2
+
+         u(i) = (1._PRC - nu)*(1._PRC - 3._PRC*nu)*uold(i) &
+                + 6._PRC*nu*(1._PRC - nu)*uold(i + 1) &
+                + nu*(3._PRC*nu - 2._PRC)*uold(i + 2)
+
+      end do
+
+      do i = 1, sizex - 1, 2
+
+         u(i) = nu**2*(nu - 1._PRC)*uold(i + 3) &
+                + nu**2*(3._PRC - 2._PRC*nu)*uold(i + 2) &
+                + nu*(1._PRC - nu)*uold(i + 1) &
+                + (1._PRC - nu)**2*(1._PRC + 2._PRC*nu)*uold(i) &
+                - nu*(1._PRC - nu)**2*uold(i - 1)
+
+      end do
+
+   end if
+
+end subroutine advection_super_simple
+
+subroutine advection_super_simplev(u, sizex, BD, speed)
+   use definitions
+   implicit none
+
+   integer :: sizex, BD
+   real(kind=PRC) :: speed
+   real(kind=PRC) :: u(-BD:sizex + BD)
+
+   integer :: i
+   real(kind=PRC) :: nu
+   real(kind=PRC), dimension(-BD:sizex + BD) :: uold
+
+   uold(:) = u(:)
+
+   !evolution
+   nu = abs(speed) !CFL
+
+   ! no flux bd condition
+   u(0) = 0._PRC
+   u(sizex) = 0._PRC
+
+   !positive advection velocity
+   if (speed >= 0.) then
+
+      !interface update formula
+      do i = 2, sizex - 2, 2
+
+         u(i) = nu*(3._PRC*nu - 2._PRC)*uold(i - 2) &
+                + 6._PRC*nu*(1._PRC - nu)*uold(i - 1) &
+                + (1._PRC - nu)*(1._PRC - 3._PRC*nu)*uold(i)
+
+      end do
+
+      !average update formula
+      do i = 3, sizex - 3, 2
+
+         u(i) = nu**2*(nu - 1._PRC)*uold(i - 3) &
+                + nu**2*(3._PRC - 2._PRC*nu)*uold(i - 2) &
+                + nu*(1._PRC - nu)*uold(i - 1) &
+                + (1._PRC - nu)**2*(1._PRC + 2._PRC*nu)*uold(i) &
+                - nu*(1._PRC - nu)**2*uold(i + 1)
+
+      end do
+
+      ! no flux between outer averages and bd
+      u(1) = -nu**2*(nu - 1._PRC)*uold(0) &
+             + (1._PRC - nu**2*(3._PRC - 2._PRC*nu))*uold(1) &
+             - nu*(1._PRC - nu)**2*uold(2)
+
+      u(sizex - 1) = uold(sizex - 1) + nu*(1._PRC - nu)**2*uold(sizex - 2) &
+                     + nu**2*(3._PRC - 2._PRC*nu)*uold(sizex - 3) + nu**2*(nu - 1._PRC)*uold(sizex - 4)
+
+      !negative advection velocity
+   else if (speed < 0.) then
+
+      do i = 2, sizex - 2, 2
+
+         u(i) = (1._PRC - nu)*(1._PRC - 3._PRC*nu)*uold(i) &
+                + 6._PRC*nu*(1._PRC - nu)*uold(i + 1) &
+                + nu*(3._PRC*nu - 2._PRC)*uold(i + 2)
+
+      end do
+
+      do i = 3, sizex - 3, 2
+
+         u(i) = nu**2*(nu - 1._PRC)*uold(i + 3) &
+                + nu**2*(3._PRC - 2._PRC*nu)*uold(i + 2) &
+                + nu*(1._PRC - nu)*uold(i + 1) &
+                + (1._PRC - nu)**2*(1._PRC + 2._PRC*nu)*uold(i) &
+                - nu*(1._PRC - nu)**2*uold(i - 1)
+
+      end do
+
+      ! no flux bd
+      u(1) = uold(1) + nu*(1._PRC - nu)**2*uold(2) &
+             + nu**2*(3._PRC - 2._PRC*nu)*uold(3) + nu**2*(nu - 1._PRC)*uold(4)
+
+      u(sizex - 1) = -nu**2*(nu - 1._PRC)*uold(sizex - 0) &
+                     + (1._PRC - nu**2*(3._PRC - 2._PRC*nu))*uold(sizex - 1) &
+                     - nu*(1._PRC - nu)**2*uold(sizex - 2)
+
+   end if
+
+end subroutine advection_super_simplev
+
