+  c0 = 18.174; // A1, A2
+  //c0 = 38.222; // B1, B2
+  mu0 = 1.;
+  eps0 = 1./(c0*c0);
+
+  // setup specific
+  setup = "orszag_tang";
+  
+
+  setup_var["n_bg"] = 1.;
+  setup_var["L"] = 4. * M_PI; // Groselj et al.: 8. * M_PI
+  setup_var["delta_u"] = 0.2; // A1
+  //setup_var["delta_u"] = 0.1; // A2
+  //setup_var["delta_u"] = 0.3; // B1
+  //setup_var["delta_u"] = 0.15; // B2
+
+  // domain
+  nproc[0] = 8;
+  nproc[1] = 4;
+  nproc[2] = 1;
+
+  res_x_total[0] = 128;
+  res_x_total[1] = 128;
+  res_x_total[2] = 1;
+
+  for (int i = 0; i < nspecies; ++i) {
+    species[i].res_v[0] = 16;
+    species[i].res_v[1] = 16;
+    species[i].res_v[2] = 16;
+  }
+
+  bd[0] = 2;
+  bd[1] = 2;
+  bd[2] = 2;
+
