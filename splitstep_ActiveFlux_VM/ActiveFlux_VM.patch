+                            j(x,y,z,2) = j(x,y,z,2) + vyVal*d3v_q_i*f_i(x,y,z,vx,vy,vz)*w;
+                            j(x,y,z,3) = j(x,y,z,3) + vzVal*d3v_q_e*f_e(x,y,z,vx,vy,vz)*w;
+                        enddo
+                    enddo
+                enddo
+            enddo
+        enddo
+    enddo
+    !$acc end parallel
+
+    !$acc end data
+
+
+end subroutine convert_f_to_j_af
